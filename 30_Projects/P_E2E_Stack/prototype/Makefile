phase4-linkage-smoke:
	$(PYTHON) "$(PHASE4_LINKAGE_RUNNER)" \
		--matrix "$(PHASE4_LINKAGE_MATRIX)" \
		--checklist "$(PHASE4_LINKAGE_CHECKLIST)" \
		--reference-map "$(PHASE4_LINKAGE_REFERENCE_MAP)" \
		$(foreach module,$(PHASE4_LINKAGE_MODULES),--module "$(module)") \
		--out "$(PHASE4_LINKAGE_OUT)"

phase4-reference-pattern-smoke:
	$(PYTHON) "$(PHASE4_REFERENCE_PATTERN_RUNNER)" \
		--reference-map "$(PHASE4_LINKAGE_REFERENCE_MAP)" \
		--reference-index "$(PHASE4_REFERENCE_INDEX)" \
		--min-coverage-ratio "$(PHASE4_REFERENCE_PATTERN_MIN_COVERAGE_RATIO)" \
		$(PHASE4_REFERENCE_PATTERN_SECONDARY_MIN_COVERAGE_RATIO_FLAG) \
		$(foreach module,$(PHASE4_REFERENCE_PATTERN_MODULES),--module "$(module)") \
		--out "$(PHASE4_REFERENCE_PATTERN_OUT)"

