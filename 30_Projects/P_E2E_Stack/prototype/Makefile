runtime-native-summary-compare-strict-check:
	@if [ -z "$(RUNTIME_NATIVE_SUMMARY_COMPARE_STRICT_SUMMARY_JSON)" ]; then \
		echo "[error] RUNTIME_NATIVE_SUMMARY_COMPARE_STRICT_SUMMARY_JSON is required" >&2; \
		exit 2; \
	fi
	$(PYTHON) "$(RUNTIME_NATIVE_SUMMARY_COMPARE_STRICT_CHECK_RUNNER)" \
		--summary-json "$(RUNTIME_NATIVE_SUMMARY_COMPARE_STRICT_SUMMARY_JSON)"

runtime-native-summary-compare:
	$(PYTHON) "$(RUNTIME_NATIVE_SUMMARY_COMPARE_RUNNER)" \
		--report-dir "$(REPORT_DIR)" \
		--left-release-prefix "$(RUNTIME_NATIVE_SUMMARY_COMPARE_LEFT_RELEASE_PREFIX)" \
		--right-release-prefix "$(RUNTIME_NATIVE_SUMMARY_COMPARE_RIGHT_RELEASE_PREFIX)" \
		--versions "$(RUNTIME_NATIVE_SUMMARY_COMPARE_VERSIONS)" \
		--left-label "$(RUNTIME_NATIVE_SUMMARY_COMPARE_LEFT_LABEL)" \
		--right-label "$(RUNTIME_NATIVE_SUMMARY_COMPARE_RIGHT_LABEL)" \
		--out-json "$(RUNTIME_NATIVE_SUMMARY_COMPARE_OUT_JSON)" \
		--out-text "$(RUNTIME_NATIVE_SUMMARY_COMPARE_OUT_TEXT)"

runtime-native-summary-compare-e2e-smoke:
	$(PYTHON) run_ci_summary.py \
		--python-bin "$(PYTHON)" \
		--artifacts-root "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_ARTIFACTS_ROOT)" \
		--summary-files-root "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_ARTIFACTS_ROOT)/reports" \
		--summary-files-subpath "" \
		--pipeline-manifests-root "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_ARTIFACTS_ROOT)/batch_runs" \
		--pipeline-manifests-subpath "" \
		--release-prefix "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_RELEASE_PREFIX)" \
		--out-text "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_OUT_PREFIX).summary.txt" \
		--out-json "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_OUT_PREFIX).summary.json" \
		--out-db "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_OUT_PREFIX).summary.sqlite" \
		--summary-title "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_SUMMARY_TITLE)" \
		--workflow-name "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_WORKFLOW_NAME)" \
		--notification-out-json "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_OUT_PREFIX).notification.json" \
		--step-summary-file "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_OUT_PREFIX).step_summary.md" \
		--version-a "$(VERSION_A)" \
		--version-b "$(VERSION_B)" \
		--hold-reason-limit "$(HOLD_REASON_LIMIT)" \
		--notify-on "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_NOTIFY_ON)" \
		--notify-format "$(RUNTIME_NATIVE_SUMMARY_COMPARE_E2E_NOTIFY_FORMAT)"

