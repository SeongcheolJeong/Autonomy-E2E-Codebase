		--trend-min-pass-rate "$(TREND_MIN_PASS_RATE)" \
		--trend-min-samples "$(TREND_MIN_SAMPLES)" \
		--dry-run

pipeline-matrix:
	$(PYTHON) run_ci_matrix_pipeline.py $(MATRIX_RUN_BASE_ARGS)

pipeline-matrix-dry-run:
	$(PYTHON) run_ci_matrix_pipeline.py $(MATRIX_RUN_BASE_ARGS) --dry-run

runtime-assets-prepare:
	$(PYTHON) "$(RUNTIME_ASSET_PREP_RUNNER)" \
		--manifest "$(RUNTIME_ASSET_MANIFEST)" \
		--runtime "$(RUNTIME_ASSET_RUNTIME)" \
		--profile "$(RUNTIME_ASSET_PROFILE)" \
		--archive-sha256-mode "$(RUNTIME_ASSET_PREP_ARCHIVE_SHA256_MODE)" \
		--archives-root "$(RUNTIME_ASSET_ARCHIVES_ROOT)" \
		--assets-root "$(RUNTIME_ASSET_ROOT)" \
		--resolved-out "$(RUNTIME_ASSET_RESOLVED_OUT)" \
		--env-out "$(RUNTIME_ASSET_ENV_OUT)" \
		$(RUNTIME_ASSET_SKIP_DOWNLOAD_FLAG) \
		$(RUNTIME_ASSET_SKIP_EXTRACT_FLAG) \
		$(RUNTIME_ASSET_FORCE_DOWNLOAD_FLAG) \
		$(RUNTIME_ASSET_FORCE_EXTRACT_FLAG) \
		$(RUNTIME_ASSET_REQUIRE_RUNTIME_BIN_FLAG) \
		$(RUNTIME_ASSET_REQUIRE_HOST_COMPATIBLE_FLAG)

pipeline-runtime-available-precheck:
	$(MAKE) runtime-assets-prepare \
		RUNTIME_ASSET_RUNTIME="$(RUNTIME_AVAILABLE_SIM_RUNTIME)" \
		RUNTIME_ASSET_PROFILE="$(RUNTIME_AVAILABLE_ASSET_PROFILE)" \
		RUNTIME_ASSET_RESOLVED_OUT="$(RUNTIME_AVAILABLE_ASSET_RESOLVED_OUT)" \
		RUNTIME_ASSET_ENV_OUT="$(RUNTIME_AVAILABLE_ASSET_ENV_OUT)" \
		RUNTIME_ASSET_PREP_SKIP_DOWNLOAD="$(RUNTIME_AVAILABLE_ASSET_SKIP_DOWNLOAD)" \
		RUNTIME_ASSET_PREP_SKIP_EXTRACT="$(RUNTIME_AVAILABLE_ASSET_SKIP_EXTRACT)" \
		RUNTIME_ASSET_PREP_FORCE_DOWNLOAD="$(RUNTIME_AVAILABLE_ASSET_FORCE_DOWNLOAD)" \
		RUNTIME_ASSET_PREP_FORCE_EXTRACT="$(RUNTIME_AVAILABLE_ASSET_FORCE_EXTRACT)" \
		RUNTIME_ASSET_PREP_REQUIRE_RUNTIME_BIN="$(RUNTIME_AVAILABLE_ASSET_REQUIRE_RUNTIME_BIN)" \
		RUNTIME_ASSET_PREP_REQUIRE_HOST_COMPATIBLE="$(RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE)" \
		RUNTIME_ASSET_PREP_ARCHIVE_SHA256_MODE="$(RUNTIME_AVAILABLE_ASSET_ARCHIVE_SHA256_MODE)"

