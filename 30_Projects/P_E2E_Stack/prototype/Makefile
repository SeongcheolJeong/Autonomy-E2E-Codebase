		INPUT_NOTIFY_PHASE3_VEHICLE_SPEED_TRACKING_ERROR_ABS_WARN_MAX="$(WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_NOTIFY_PHASE3_VEHICLE_SPEED_TRACKING_ERROR_ABS_WARN_MAX)" \
		INPUT_NOTIFY_PHASE3_VEHICLE_SPEED_TRACKING_ERROR_ABS_HOLD_MAX="$(WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_NOTIFY_PHASE3_VEHICLE_SPEED_TRACKING_ERROR_ABS_HOLD_MAX)" \
		bash "$(WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_RUNNER)"

workflow-runtime-available-dispatch-dry-run:
	@$(MAKE) workflow-runtime-available-dispatch \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_DRY_RUN=1

workflow-runtime-available-dispatch-both-exec:
	@$(MAKE) workflow-runtime-available-dispatch \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_SIM_RUNTIME=both \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_LANE=exec \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_RUNTIME_NATIVE_SIM_RUNTIME=both \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_RUNTIME_NATIVE_SUMMARY_COMPARE_FAIL_ON_MISSING=1 \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_RUNTIME_NATIVE_SUMMARY_COMPARE_FAIL_ON_DIFFS="$(WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_BOTH_EXEC_RUNTIME_NATIVE_SUMMARY_COMPARE_FAIL_ON_DIFFS)" \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_CONTINUE_ON_RUNTIME_FAILURE=0 \
		WORKFLOW_RUNTIME_AVAILABLE_DISPATCH_REQUIRE_RUN_SUCCESS=1

