		--matrix "$(PARITY_GAP_MATRIX)" \
		--master-plan "$(PARITY_GAP_MASTER_PLAN)" \
		--checklist "$(PARITY_GAP_CHECKLIST_PHASE1)" \
		--checklist "$(PARITY_GAP_CHECKLIST_PHASE2)" \
		--checklist "$(PARITY_GAP_CHECKLIST_PHASE3)" \
		--checklist "$(PARITY_GAP_CHECKLIST_PHASE4)" \
		--out-json "$(PARITY_GAP_OUT_JSON)" \
		--out-markdown "$(PARITY_GAP_OUT_MARKDOWN)" \
		--fail-on-open-gaps "$(PARITY_GAP_FAIL_ON_OPEN_GAPS)"

