				BATCH_SPEC="$$BATCH_SPEC" \
				RELEASE_ID="$$RELEASE_ID" \
				RUNTIME_NATIVE_ENTRY_PHASE3_ENABLE_HOOKS="$$RUNTIME_NATIVE_ENTRY_PHASE3_ENABLE_HOOKS" \
