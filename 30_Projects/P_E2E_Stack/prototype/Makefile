runtime-evidence-compare:
	@if [ -z "$(RUNTIME_EVIDENCE_COMPARE_LEFT)" ]; then \
		echo "[error] RUNTIME_EVIDENCE_COMPARE_LEFT is required" >&2; \
		exit 2; \
	fi
	@if [ -z "$(RUNTIME_EVIDENCE_COMPARE_RIGHT)" ]; then \
		echo "[error] RUNTIME_EVIDENCE_COMPARE_RIGHT is required" >&2; \
		exit 2; \
	fi
	$(PYTHON) compare_runtime_evidence.py \
		--left "$(RUNTIME_EVIDENCE_COMPARE_LEFT)" \
		--right "$(RUNTIME_EVIDENCE_COMPARE_RIGHT)" \
		--left-label "$(RUNTIME_EVIDENCE_COMPARE_LEFT_LABEL)" \
		--right-label "$(RUNTIME_EVIDENCE_COMPARE_RIGHT_LABEL)" \
		--out-json "$(RUNTIME_EVIDENCE_COMPARE_OUT_JSON)" \
		--out-text "$(RUNTIME_EVIDENCE_COMPARE_OUT_TEXT)"

pipeline-matrix-summary:
	@set -e; \
	rc=0; \
	$(PYTHON) run_ci_matrix_pipeline.py $(MATRIX_RUN_BASE_ARGS) \
	|| rc=$$?; \
	$(PYTHON) run_ci_summary.py $(SUMMARY_RUN_BASE_ARGS); \
	exit $$rc

pipeline-matrix-summary-dry-run:
	@set -e; \
	rc=0; \
	$(PYTHON) run_ci_matrix_pipeline.py $(MATRIX_RUN_BASE_ARGS) --dry-run \
	|| rc=$$?; \
	$(PYTHON) run_ci_summary.py $(SUMMARY_RUN_BASE_ARGS) --dry-run; \
	exit $$rc

