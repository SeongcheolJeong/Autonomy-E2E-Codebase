	--profile-ids-csv "$(MATRIX_PROFILE_IDS)" \
	--release-prefix "$(RELEASE_ID)" \
	--gate-profile "$(GATE_PROFILE)" \
	--requirement-map "$(REQUIREMENT_MAP)" \
	--strict-gate-input "$(STRICT_GATE)" \
	--trend-window "$(TREND_WINDOW)" \
	--trend-min-pass-rate "$(TREND_MIN_PASS_RATE)" \
	--trend-min-samples "$(TREND_MIN_SAMPLES)" \
	--phase2-route-gate-require-status-pass-input "$(PHASE2_ROUTE_GATE_REQUIRE_STATUS_PASS)" \
	--phase2-route-gate-require-routing-semantic-pass-input "$(PHASE2_ROUTE_GATE_REQUIRE_ROUTING_SEMANTIC_PASS)" \
