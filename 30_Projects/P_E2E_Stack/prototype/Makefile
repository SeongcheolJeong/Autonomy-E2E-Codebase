pipeline-runtime-native-entry-smoke-docker-linux-auto:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@if "$(DOCKER_BIN)" image inspect "$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" >/dev/null 2>&1; then \
		echo "[info] runtime-native-entry docker auto lane=fast-nobuild image=$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)"; \
		$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-fast-nobuild; \
	else \
		echo "[info] runtime-native-entry docker auto lane=fast-build image=$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)"; \
		$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-fast; \
	fi

pipeline-runtime-native-entry-smoke-docker-linux-auto-dry-run:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@if "$(DOCKER_BIN)" image inspect "$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" >/dev/null 2>&1; then \
		echo "[info] runtime-native-entry docker auto lane=fast-nobuild image=$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)"; \
		$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-fast-nobuild-dry-run; \
	else \
		echo "[info] runtime-native-entry docker auto lane=fast-build image=$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)"; \
		$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-fast-dry-run; \
	fi

pipeline-runtime-available-smoke: $(RUNTIME_AVAILABLE_PRECHECK_TARGET)
	@set -a; \
	if [ -f "$(RUNTIME_AVAILABLE_ASSET_ENV_OUT)" ]; then \
		. "$(RUNTIME_AVAILABLE_ASSET_ENV_OUT)"; \
	fi; \
	set +a; \
		$(MAKE) pipeline-matrix \
			MATRIX_PROFILE_FILE="$(RUNTIME_MATRIX_PROFILE_FILE)" \
			MATRIX_PROFILE_IDS="$(RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS)" \
			PHASE3_ENABLE_HOOKS="$(RUNTIME_AVAILABLE_PHASE3_ENABLE_HOOKS)" \
