		--world-state "$(WORLD_STATE)" \
		--sensor-rig "$(SENSOR_RIG)" \
		--out "$(SENSOR_FRAME_OUT)" \
		--fidelity-tier "$(SENSOR_BRIDGE_FIDELITY_TIER)"

