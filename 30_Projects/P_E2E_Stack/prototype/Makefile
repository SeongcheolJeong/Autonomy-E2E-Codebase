pipeline-runtime-native-entry-smoke-auto:
	@host_os="$$(uname -s)"; \
	host_arch="$$(uname -m)"; \
	force_lane="$(RUNTIME_NATIVE_ENTRY_AUTO_FORCE_LANE)"; \
	case "$$force_lane" in \
		auto|direct|docker) ;; \
		*) \
			echo "[error] RUNTIME_NATIVE_ENTRY_AUTO_FORCE_LANE must be one of: auto, direct, docker" >&2; \
			exit 2; \
			;; \
	esac; \
	continue_on_failure="$(RUNTIME_NATIVE_ENTRY_AUTO_CONTINUE_ON_RUNTIME_FAILURE)"; \
	case "$$continue_on_failure" in \
		0|1) ;; \
		*) \
			echo "[error] RUNTIME_NATIVE_ENTRY_AUTO_CONTINUE_ON_RUNTIME_FAILURE must be 0 or 1" >&2; \
			exit 2; \
			;; \
	esac; \
	if [ "$$force_lane" = "auto" ]; then \
		if [ "$$host_os" = "Linux" ] && [ "$$host_arch" = "x86_64" ]; then \
			lane="direct"; \
			echo "[info] runtime-native-entry auto lane=direct host=$$host_os/$$host_arch"; \
		else \
			lane="docker"; \
			echo "[info] runtime-native-entry auto lane=docker host=$$host_os/$$host_arch"; \
		fi; \
	else \
		lane="$$force_lane"; \
		echo "[info] runtime-native-entry auto lane=$$lane (forced) host=$$host_os/$$host_arch"; \
	fi; \
	sim_runtime="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME)"; \
	case "$$sim_runtime" in \
		both) runtimes="awsim carla" ;; \
		awsim|carla) runtimes="$$sim_runtime" ;; \
		*) \
			echo "[error] RUNTIME_NATIVE_ENTRY_SIM_RUNTIME must be one of: awsim, carla, both" >&2; \
			exit 2; \
			;; \
	esac; \
	runtime_count=0; \
	for runtime_value in $$runtimes; do \
		runtime_count=$$((runtime_count + 1)); \
	done; \
	runtime_failures=0; \
	for runtime_value in $$runtimes; do \
		runtime_release_id="$(RELEASE_ID)"; \
		if [ "$$runtime_count" -gt 1 ]; then \
			runtime_release_id="$(RELEASE_ID)_$$runtime_value"; \
		fi; \
		runtime_evidence_out="$(REPORT_DIR)/$${runtime_release_id}_runtime_native_entry_evidence.json"; \
		echo "[info] runtime-native-entry auto runtime=$$runtime_value release_id=$$runtime_release_id lane=$$lane"; \
		if [ "$$lane" = "direct" ]; then \
			if ! $(MAKE) pipeline-runtime-native-entry-smoke \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_EVIDENCE_OUT="$$runtime_evidence_out" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME="$$runtime_value"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		else \
			if ! $(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-auto \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_EVIDENCE_OUT="$$runtime_evidence_out" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME="$$runtime_value"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		fi; \
	done; \
	if [ "$$runtime_failures" -gt 0 ]; then \
		exit 1; \
	fi

