				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_EXECUTE="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_EXECUTE" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_ENABLE="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_ENABLE" \
				RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY" \
					RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE" \
					RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY" \
					RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE" \
					RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_XOSC="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_XOSC" \
					RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_XODR="$$RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_XODR" \
