pipeline-runtime-native-entry-smoke-docker-linux-dry-run:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@"$(DOCKER_BIN)" run --rm --platform "$(RUNTIME_NATIVE_ENTRY_DOCKER_PLATFORM)" \
		-v "$(REPO_ROOT):/work" \
		-w "$(RUNTIME_NATIVE_ENTRY_DOCKER_WORKDIR)" \
		-e BATCH_SPEC="$(BATCH_SPEC)" \
		-e RELEASE_ID="$(RELEASE_ID)" \
		-e RUNTIME_NATIVE_ENTRY_PHASE3_ENABLE_HOOKS="$(RUNTIME_NATIVE_ENTRY_PHASE3_ENABLE_HOOKS)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_MODE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_MODE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_ENABLE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_ENABLE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_EXECUTE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_EXECUTE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_ENABLE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_ENABLE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE)" \
		-e RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY="$(RUNTIME_NATIVE_ENTRY_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY)" \
