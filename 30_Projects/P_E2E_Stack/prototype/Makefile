pipeline-runtime-available-docker-image-build:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@"$(DOCKER_BIN)" build --platform "$(RUNTIME_AVAILABLE_DOCKER_PLATFORM)" \
		-f "$(REPO_ROOT)/$(RUNTIME_AVAILABLE_DOCKERFILE)" \
		-t "$(RUNTIME_AVAILABLE_DOCKER_PREBUILT_IMAGE)" \
		"$(REPO_ROOT)"
	@echo "[ok] runtime_available_docker_image=$(RUNTIME_AVAILABLE_DOCKER_PREBUILT_IMAGE)"

pipeline-runtime-available-auto-docker-linux-fast: pipeline-runtime-available-docker-image-build
	@$(MAKE) pipeline-runtime-available-auto-docker-linux-fast-nobuild

pipeline-runtime-available-auto-docker-linux-fast-dry-run: pipeline-runtime-available-docker-image-build
	@$(MAKE) pipeline-runtime-available-auto-docker-linux-fast-nobuild-dry-run

pipeline-runtime-available-auto-docker-linux-fast-nobuild:
	@$(MAKE) pipeline-runtime-available-auto-docker-linux \
		RUNTIME_AVAILABLE_DOCKER_IMAGE="$(RUNTIME_AVAILABLE_DOCKER_PREBUILT_IMAGE)" \
		RUNTIME_AVAILABLE_DOCKER_SKIP_APT=1

pipeline-runtime-available-auto-docker-linux-fast-nobuild-dry-run:
	@$(MAKE) pipeline-runtime-available-auto-docker-linux-dry-run \
		RUNTIME_AVAILABLE_DOCKER_IMAGE="$(RUNTIME_AVAILABLE_DOCKER_PREBUILT_IMAGE)" \
		RUNTIME_AVAILABLE_DOCKER_SKIP_APT=1

pipeline-runtime-available-auto-docker-linux-fast-nobuild-both-compare:
	@set -e; \
	base_release_id="$(RELEASE_ID)"; \
	left="$(REPORT_DIR)/$${base_release_id}_awsim_runtime_available_evidence.json"; \
	right="$(REPORT_DIR)/$${base_release_id}_carla_runtime_available_evidence.json"; \
	$(MAKE) pipeline-runtime-available-auto-docker-linux-fast-nobuild \
		RELEASE_ID="$$base_release_id" \
		RUNTIME_AVAILABLE_SIM_RUNTIME=both \
		RUNTIME_AVAILABLE_AUTO_FORCE_LANE=exec; \
	$(MAKE) runtime-evidence-compare \
		RELEASE_ID="$$base_release_id" \
		RUNTIME_EVIDENCE_COMPARE_LEFT="$$left" \
		RUNTIME_EVIDENCE_COMPARE_RIGHT="$$right" \
		RUNTIME_EVIDENCE_COMPARE_LEFT_LABEL=awsim \
		RUNTIME_EVIDENCE_COMPARE_RIGHT_LABEL=carla \
		RUNTIME_EVIDENCE_COMPARE_OUT_JSON="$(REPORT_DIR)/$${base_release_id}_runtime_available_both_evidence_compare.json" \
		RUNTIME_EVIDENCE_COMPARE_OUT_TEXT="$(REPORT_DIR)/$${base_release_id}_runtime_available_both_evidence_compare.txt"

