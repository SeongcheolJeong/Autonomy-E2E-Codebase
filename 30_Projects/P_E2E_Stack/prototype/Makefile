pipeline-runtime-native-entry-docker-image-build:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@"$(DOCKER_BIN)" build --platform "$(RUNTIME_NATIVE_ENTRY_DOCKER_PLATFORM)" \
		-f "$(REPO_ROOT)/$(RUNTIME_NATIVE_ENTRY_DOCKERFILE)" \
		-t "$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" \
		"$(REPO_ROOT)"
	@echo "[ok] runtime_native_entry_docker_image=$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)"

pipeline-runtime-native-entry-smoke-docker-linux-fast: pipeline-runtime-native-entry-docker-image-build
	@$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux \
		RUNTIME_NATIVE_ENTRY_DOCKER_IMAGE="$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" \
		RUNTIME_NATIVE_ENTRY_DOCKER_SKIP_APT=1

pipeline-runtime-native-entry-smoke-docker-linux-fast-dry-run: pipeline-runtime-native-entry-docker-image-build
	@$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-dry-run \
		RUNTIME_NATIVE_ENTRY_DOCKER_IMAGE="$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" \
		RUNTIME_NATIVE_ENTRY_DOCKER_SKIP_APT=1

pipeline-runtime-native-entry-smoke-docker-linux-fast-nobuild:
	@$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux \
		RUNTIME_NATIVE_ENTRY_DOCKER_IMAGE="$(RUNTIME_NATIVE_ENTRY_DOCKER_PREBUILT_IMAGE)" \
		RUNTIME_NATIVE_ENTRY_DOCKER_SKIP_APT=1

pipeline-runtime-native-entry-smoke-docker-linux-fast-nobuild-dry-run:
	@$(MAKE) pipeline-runtime-native-entry-smoke-docker-linux-dry-run \
