generate-sds-batches:
	$(PYTHON) generate_sds_batches.py \
		--python-bin "$(PYTHON)" \
		--catalog-manifest "$(CATALOG_MANIFEST)" \
		--versions "$(SDS_VERSIONS)" \
		--out-dir "$(SDS_BATCH_OUTPUT_DIR)" \
		--batch-id-prefix "$(SDS_BATCH_ID_PREFIX)" \
		--batch-id-suffix "$(SDS_BATCH_ID_SUFFIX)" \
		--batch-file-prefix "$(SDS_BATCH_FILE_PREFIX)" \
		--run-id-prefix-base "$(SDS_RUN_ID_PREFIX_BASE)" \
		--seed-base "$(SDS_SEED_BASE)" \
		--seed-version-stride "$(SDS_SEED_VERSION_STRIDE)" \
		--seed-step "$(SDS_SEED_STEP)" \
		--profiles-out "$(SDS_MATRIX_PROFILES_OUT)"

ingest-smoke:
	$(PYTHON) ../../P_Data-Lake-and-Explorer/prototype/ingest_scenario_runs.py \
		--summary-root "$(SUMMARY_ROOT)" \
		--db "$(DB_PATH)"

ingest-dataset-manifest:
	$(PYTHON) ../../P_Data-Lake-and-Explorer/prototype/ingest_scenario_runs.py \
		--dataset-manifest-file "$(DATASET_MANIFEST_OUT)" \
		--db "$(DB_PATH)"

report-smoke:
	@for version in $(SDS_VERSIONS); do \
		out="$(REPORT_DIR)/$(RELEASE_ID)_$${version}.md"; \
		summary="$(REPORT_DIR)/$(RELEASE_ID)_$${version}.summary.json"; \
		echo "[report] $$version -> $$out"; \
		$(PYTHON) ../../P_Validation-Tooling-MVP/prototype/generate_release_report.py \
			--db "$(DB_PATH)" \
			--release-id "$(RELEASE_ID)_$${version}" \
			--sds-version "$$version" \
			--out "$$out" \
			--summary-out "$$summary" \
			--requirement-map "$(REQUIREMENT_MAP)" \
			--gate-profile "$(GATE_PROFILE)"; \
	done

ingest-release:
	@CMD="$(PYTHON) ../../P_Data-Lake-and-Explorer/prototype/ingest_scenario_runs.py"; \
	for version in $(SDS_VERSIONS); do \
		CMD="$$CMD --report-summary-file $(REPORT_DIR)/$(RELEASE_ID)_$${version}.summary.json"; \
	done; \
	CMD="$$CMD --db $(DB_PATH)"; \
	echo "$$CMD"; \
	eval "$$CMD"

release-latest:
	$(PYTHON) ../../P_Data-Lake-and-Explorer/prototype/query_scenario_runs.py \
		--db "$(DB_PATH)" release-latest --limit 20

dataset-latest:
	$(PYTHON) ../../P_Data-Lake-and-Explorer/prototype/query_scenario_runs.py \
		--db "$(DB_PATH)" dataset-latest --limit 20

