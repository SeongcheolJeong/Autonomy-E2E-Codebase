		--input "$(LOG_SCENE)" \
		--ego-speed-scale "1.1" \
		--lead-gap-offset-m "-5.0" \
		--out "$(LOG_AUGMENT_OUT)"

map-convert-smoke:
	$(PYTHON) ../../P_Map-Toolset-MVP/prototype/convert_map_format.py \
		--input "$(MAP_SIMPLE)" \
		--to-format canonical \
		--out "$(MAP_CANONICAL_OUT)"
	$(PYTHON) ../../P_Map-Toolset-MVP/prototype/convert_map_format.py \
		--input "$(MAP_CANONICAL_OUT)" \
		--to-format simple \
		--out "$(MAP_ROUNDTRIP_OUT)"

map-validate-smoke:
	$(PYTHON) ../../P_Map-Toolset-MVP/prototype/convert_map_format.py \
		--input "$(MAP_SIMPLE)" \
		--to-format canonical \
		--out "$(MAP_CANONICAL_OUT)"
	$(PYTHON) ../../P_Map-Toolset-MVP/prototype/validate_canonical_map.py \
		--map "$(MAP_CANONICAL_OUT)" \
		--report-out "$(MAP_VALIDATE_REPORT_OUT)"

map-route-smoke:
	$(PYTHON) ../../P_Map-Toolset-MVP/prototype/convert_map_format.py \
		--input "$(MAP_SIMPLE)" \
		--to-format canonical \
		--out "$(MAP_CANONICAL_OUT)"
	$(PYTHON) "$(MAP_ROUTE_RUNNER)" \
		--map "$(MAP_CANONICAL_OUT)" \
		--cost-mode "$(MAP_ROUTE_COST_MODE)" \
		--report-out "$(MAP_ROUTE_REPORT_OUT)" \
		--entry-lane-id "$(MAP_ROUTE_ENTRY_LANE_ID)" \
		--exit-lane-id "$(MAP_ROUTE_EXIT_LANE_ID)" \
		$(foreach lane,$(MAP_ROUTE_VIA_LANE_IDS),--via-lane-id "$(lane)")

