pipeline-runtime-native-entry-smoke-auto-both-compare:
	@set -e; \
	base_release_id="$(RELEASE_ID)"; \
	left="$(REPORT_DIR)/$${base_release_id}_awsim_runtime_native_entry_evidence.json"; \
	right="$(REPORT_DIR)/$${base_release_id}_carla_runtime_native_entry_evidence.json"; \
	$(MAKE) pipeline-runtime-native-entry-smoke-auto \
		RELEASE_ID="$$base_release_id" \
		RUNTIME_NATIVE_ENTRY_SIM_RUNTIME=both \
		RUNTIME_NATIVE_ENTRY_AUTO_CONTINUE_ON_RUNTIME_FAILURE=0; \
	$(MAKE) runtime-evidence-compare \
		RELEASE_ID="$$base_release_id" \
		RUNTIME_EVIDENCE_COMPARE_LEFT="$$left" \
		RUNTIME_EVIDENCE_COMPARE_RIGHT="$$right" \
		RUNTIME_EVIDENCE_COMPARE_LEFT_LABEL=awsim \
		RUNTIME_EVIDENCE_COMPARE_RIGHT_LABEL=carla \
		RUNTIME_EVIDENCE_COMPARE_OUT_JSON="$(REPORT_DIR)/$${base_release_id}_runtime_native_both_evidence_compare.json" \
		RUNTIME_EVIDENCE_COMPARE_OUT_TEXT="$(REPORT_DIR)/$${base_release_id}_runtime_native_both_evidence_compare.txt"; \
	$(MAKE) runtime-native-summary-compare \
		RELEASE_ID="$$base_release_id" \
		RUNTIME_NATIVE_SUMMARY_COMPARE_LEFT_RELEASE_PREFIX="$${base_release_id}_awsim" \
		RUNTIME_NATIVE_SUMMARY_COMPARE_RIGHT_RELEASE_PREFIX="$${base_release_id}_carla" \
		RUNTIME_NATIVE_SUMMARY_COMPARE_OUT_JSON="$(REPORT_DIR)/$${base_release_id}_runtime_native_both_summary_compare.json" \
		RUNTIME_NATIVE_SUMMARY_COMPARE_OUT_TEXT="$(REPORT_DIR)/$${base_release_id}_runtime_native_both_summary_compare.txt"

