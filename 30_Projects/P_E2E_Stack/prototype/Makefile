pipeline-runtime-available-contract-smoke-dry-run:
	$(MAKE) pipeline-runtime-available-precheck \
		RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE="$(RUNTIME_AVAILABLE_CONTRACT_ASSET_REQUIRE_HOST_COMPATIBLE)"
	@set -a; \
	. "$(RUNTIME_AVAILABLE_ASSET_ENV_OUT)"; \
	set +a; \
	$(MAKE) -n pipeline-runtime-available-smoke \
		RUNTIME_AVAILABLE_PRECHECK_RUNTIME_ASSETS=0 \
		SIM_RUNTIME_PROBE_RUNTIME_BIN="$$SIM_RUNTIME_PROBE_RUNTIME_BIN" \
		RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_EXECUTE=0 \
		RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY="$(RUNTIME_AVAILABLE_CONTRACT_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY)" \
		RUNTIME_AVAILABLE_RUNTIME_EVIDENCE_OUT="$(RUNTIME_AVAILABLE_CONTRACT_RUNTIME_EVIDENCE_OUT)"

pipeline-runtime-available-auto:
	@lane="$(RUNTIME_AVAILABLE_AUTO_FORCE_LANE)"; \
	host_os="$$(uname -s)"; \
	host_arch="$$(uname -m)"; \
	if [ "$$lane" = "auto" ]; then \
		if [ "$$host_os" = "Linux" ] && [ "$$host_arch" = "x86_64" ]; then \
			lane="exec"; \
		else \
			lane="contract"; \
		fi; \
	fi; \
	continue_on_failure="$(RUNTIME_AVAILABLE_AUTO_CONTINUE_ON_RUNTIME_FAILURE)"; \
	case "$$continue_on_failure" in \
		0|1) ;; \
		*) \
			echo "[error] RUNTIME_AVAILABLE_AUTO_CONTINUE_ON_RUNTIME_FAILURE must be 0 or 1" >&2; \
			exit 2; \
			;; \
	esac; \
	sim_runtime="$(RUNTIME_AVAILABLE_SIM_RUNTIME)"; \
	case "$$sim_runtime" in \
		both) runtimes="awsim carla" ;; \
		awsim|carla) runtimes="$$sim_runtime" ;; \
		*) \
			echo "[error] RUNTIME_AVAILABLE_SIM_RUNTIME must be one of: awsim, carla, both" >&2; \
			exit 2; \
			;; \
	esac; \
	runtime_count=0; \
	for runtime_value in $$runtimes; do \
		runtime_count=$$((runtime_count + 1)); \
	done; \
	runtime_failures=0; \
	for runtime_value in $$runtimes; do \
		runtime_release_id="$(RELEASE_ID)"; \
		if [ "$$runtime_count" -gt 1 ]; then \
			runtime_release_id="$(RELEASE_ID)_$$runtime_value"; \
		fi; \
		runtime_matrix_profile_ids="$$( \
			$(PYTHON) "$(RUNTIME_AVAILABLE_PROFILE_RESOLVER)" \
				--profiles-file "$(RUNTIME_MATRIX_PROFILE_FILE)" \
				--profile-ids-csv "$(RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS)" \
				--sim-runtime "$$runtime_value" \
		)"; \
		if [ -z "$$runtime_matrix_profile_ids" ]; then \
			echo "[error] no matrix profiles resolved for runtime=$$runtime_value" >&2; \
			exit 2; \
		fi; \
		if [ "$$lane" = "exec" ]; then \
			echo "[info] runtime-available auto lane=exec host=$$host_os/$$host_arch runtime=$$runtime_value release_id=$$runtime_release_id matrix_profile_ids=$$runtime_matrix_profile_ids"; \
			if ! $(MAKE) pipeline-runtime-available-smoke \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_AVAILABLE_SIM_RUNTIME="$$runtime_value" \
				RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$$runtime_matrix_profile_ids"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		elif [ "$$lane" = "contract" ]; then \
			echo "[info] runtime-available auto lane=contract host=$$host_os/$$host_arch runtime=$$runtime_value release_id=$$runtime_release_id matrix_profile_ids=$$runtime_matrix_profile_ids"; \
			if ! $(MAKE) pipeline-runtime-available-contract-smoke \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_AVAILABLE_SIM_RUNTIME="$$runtime_value" \
				RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$$runtime_matrix_profile_ids"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		else \
			echo "[error] RUNTIME_AVAILABLE_AUTO_FORCE_LANE must be one of: auto, exec, contract" >&2; \
			exit 2; \
		fi; \
	done; \
	if [ "$$runtime_failures" -gt 0 ]; then \
		exit 1; \
	fi

pipeline-runtime-available-auto-dry-run:
	@lane="$(RUNTIME_AVAILABLE_AUTO_FORCE_LANE)"; \
	host_os="$$(uname -s)"; \
	host_arch="$$(uname -m)"; \
	if [ "$$lane" = "auto" ]; then \
		if [ "$$host_os" = "Linux" ] && [ "$$host_arch" = "x86_64" ]; then \
			lane="exec"; \
		else \
			lane="contract"; \
		fi; \
	fi; \
	continue_on_failure="$(RUNTIME_AVAILABLE_AUTO_CONTINUE_ON_RUNTIME_FAILURE)"; \
	case "$$continue_on_failure" in \
		0|1) ;; \
		*) \
			echo "[error] RUNTIME_AVAILABLE_AUTO_CONTINUE_ON_RUNTIME_FAILURE must be 0 or 1" >&2; \
			exit 2; \
			;; \
	esac; \
	sim_runtime="$(RUNTIME_AVAILABLE_SIM_RUNTIME)"; \
	case "$$sim_runtime" in \
		both) runtimes="awsim carla" ;; \
		awsim|carla) runtimes="$$sim_runtime" ;; \
		*) \
			echo "[error] RUNTIME_AVAILABLE_SIM_RUNTIME must be one of: awsim, carla, both" >&2; \
			exit 2; \
			;; \
	esac; \
	runtime_count=0; \
	for runtime_value in $$runtimes; do \
		runtime_count=$$((runtime_count + 1)); \
	done; \
	runtime_failures=0; \
	for runtime_value in $$runtimes; do \
		runtime_release_id="$(RELEASE_ID)"; \
		if [ "$$runtime_count" -gt 1 ]; then \
			runtime_release_id="$(RELEASE_ID)_$$runtime_value"; \
		fi; \
		runtime_matrix_profile_ids="$$( \
			$(PYTHON) "$(RUNTIME_AVAILABLE_PROFILE_RESOLVER)" \
				--profiles-file "$(RUNTIME_MATRIX_PROFILE_FILE)" \
				--profile-ids-csv "$(RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS)" \
				--sim-runtime "$$runtime_value" \
		)"; \
		if [ -z "$$runtime_matrix_profile_ids" ]; then \
			echo "[error] no matrix profiles resolved for runtime=$$runtime_value" >&2; \
			exit 2; \
		fi; \
		if [ "$$lane" = "exec" ]; then \
			echo "[info] runtime-available auto lane=exec host=$$host_os/$$host_arch runtime=$$runtime_value release_id=$$runtime_release_id matrix_profile_ids=$$runtime_matrix_profile_ids"; \
			if ! $(MAKE) pipeline-runtime-available-smoke-dry-run \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_AVAILABLE_SIM_RUNTIME="$$runtime_value" \
				RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$$runtime_matrix_profile_ids"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		elif [ "$$lane" = "contract" ]; then \
			echo "[info] runtime-available auto lane=contract host=$$host_os/$$host_arch runtime=$$runtime_value release_id=$$runtime_release_id matrix_profile_ids=$$runtime_matrix_profile_ids"; \
			if ! $(MAKE) pipeline-runtime-available-contract-smoke-dry-run \
				RELEASE_ID="$$runtime_release_id" \
				RUNTIME_AVAILABLE_SIM_RUNTIME="$$runtime_value" \
				RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$$runtime_matrix_profile_ids"; then \
				runtime_failures=$$((runtime_failures + 1)); \
				if [ "$$continue_on_failure" != "1" ]; then \
					exit 1; \
				fi; \
			fi; \
		else \
			echo "[error] RUNTIME_AVAILABLE_AUTO_FORCE_LANE must be one of: auto, exec, contract" >&2; \
			exit 2; \
		fi; \
	done; \
	if [ "$$runtime_failures" -gt 0 ]; then \
		exit 1; \
	fi

pipeline-runtime-available-auto-docker-linux:
	@command -v "$(DOCKER_BIN)" >/dev/null 2>&1 || { \
		echo "[error] docker is not installed or not in PATH (DOCKER_BIN=$(DOCKER_BIN))" >&2; \
		exit 2; \
	}
	@"$(DOCKER_BIN)" run --rm --platform "$(RUNTIME_AVAILABLE_DOCKER_PLATFORM)" \
		-v "$(REPO_ROOT):/work" \
		-w "$(RUNTIME_AVAILABLE_DOCKER_WORKDIR)" \
		-e RELEASE_ID="$(RELEASE_ID)" \
		-e RUNTIME_AVAILABLE_SIM_RUNTIME="$(RUNTIME_AVAILABLE_SIM_RUNTIME)" \
		-e RUNTIME_AVAILABLE_AUTO_FORCE_LANE="$(RUNTIME_AVAILABLE_AUTO_FORCE_LANE)" \
		-e RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$(RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS)" \
			-e RUNTIME_AVAILABLE_ASSET_PROFILE="$(RUNTIME_AVAILABLE_ASSET_PROFILE)" \
			-e RUNTIME_AVAILABLE_ASSET_SKIP_DOWNLOAD="$(RUNTIME_AVAILABLE_ASSET_SKIP_DOWNLOAD)" \
			-e RUNTIME_AVAILABLE_ASSET_SKIP_EXTRACT="$(RUNTIME_AVAILABLE_ASSET_SKIP_EXTRACT)" \
			-e RUNTIME_AVAILABLE_ASSET_FORCE_DOWNLOAD="$(RUNTIME_AVAILABLE_ASSET_FORCE_DOWNLOAD)" \
			-e RUNTIME_AVAILABLE_ASSET_FORCE_EXTRACT="$(RUNTIME_AVAILABLE_ASSET_FORCE_EXTRACT)" \
			-e RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_EXECUTE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_EXECUTE)" \
			-e RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY="$(RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY)" \
			-e RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE)" \
			-e RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY="$(RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_ENABLE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_ENABLE)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY="$(RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_RUNNER="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_RUNNER)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XOSC_OUT="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XOSC_OUT)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XODR_OUT="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XODR_OUT)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_OUT="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_OUT)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_OUT="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_OUT)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XOSC="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XOSC)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XODR="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XODR)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_MANIFEST_CONSISTENCY_MODE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_MANIFEST_CONSISTENCY_MODE)" \
				-e RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_EXPORT_CONSISTENCY_MODE="$(RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_EXPORT_CONSISTENCY_MODE)" \
			-e RUNTIME_AVAILABLE_SIM_RUNTIME_ASSERT_ARTIFACTS="$(RUNTIME_AVAILABLE_SIM_RUNTIME_ASSERT_ARTIFACTS)" \
			-e RUNTIME_AVAILABLE_PRECHECK_RUNTIME_ASSETS="$(RUNTIME_AVAILABLE_PRECHECK_RUNTIME_ASSETS)" \
			-e RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE="$(RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE)" \
			-e RUNTIME_AVAILABLE_ASSET_ARCHIVE_SHA256_MODE="$(RUNTIME_AVAILABLE_ASSET_ARCHIVE_SHA256_MODE)" \
		-e RUNTIME_AVAILABLE_DOCKER_SKIP_APT="$(RUNTIME_AVAILABLE_DOCKER_SKIP_APT)" \
		"$(RUNTIME_AVAILABLE_DOCKER_IMAGE)" \
		bash -lc 'set -euo pipefail; \
			if [ "$$RUNTIME_AVAILABLE_DOCKER_SKIP_APT" != "1" ]; then \
				export DEBIAN_FRONTEND=noninteractive; \
				apt-get update >/tmp/apt.update.log; \
				if apt-cache show libasound2t64 >/dev/null 2>&1; then audio_pkg=libasound2t64; else audio_pkg=libasound2; fi; \
				apt-get install -y --no-install-recommends make python3 ca-certificates jq "$$audio_pkg" libglib2.0-0 libglu1-mesa libgtk-3-0 libnss3 libsdl2-2.0-0 libvulkan1 libxcursor1 libxi6 libxinerama1 libxrandr2 libxss1 libxtst6 xvfb >/tmp/apt.install.log; \
			fi; \
			make pipeline-runtime-available-auto \
				RELEASE_ID="$$RELEASE_ID" \
				RUNTIME_AVAILABLE_SIM_RUNTIME="$$RUNTIME_AVAILABLE_SIM_RUNTIME" \
				RUNTIME_AVAILABLE_AUTO_FORCE_LANE="$$RUNTIME_AVAILABLE_AUTO_FORCE_LANE" \
				RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS="$$RUNTIME_AVAILABLE_MATRIX_PROFILE_IDS" \
				RUNTIME_AVAILABLE_ASSET_PROFILE="$$RUNTIME_AVAILABLE_ASSET_PROFILE" \
					RUNTIME_AVAILABLE_ASSET_SKIP_DOWNLOAD="$$RUNTIME_AVAILABLE_ASSET_SKIP_DOWNLOAD" \
					RUNTIME_AVAILABLE_ASSET_SKIP_EXTRACT="$$RUNTIME_AVAILABLE_ASSET_SKIP_EXTRACT" \
					RUNTIME_AVAILABLE_ASSET_FORCE_DOWNLOAD="$$RUNTIME_AVAILABLE_ASSET_FORCE_DOWNLOAD" \
					RUNTIME_AVAILABLE_ASSET_FORCE_EXTRACT="$$RUNTIME_AVAILABLE_ASSET_FORCE_EXTRACT" \
					RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_EXECUTE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_EXECUTE" \
					RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY="$$RUNTIME_AVAILABLE_SIM_RUNTIME_PROBE_REQUIRE_AVAILABILITY" \
					RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_ENABLE" \
					RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY="$$RUNTIME_AVAILABLE_SIM_RUNTIME_SCENARIO_CONTRACT_REQUIRE_RUNTIME_READY" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_ENABLE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_ENABLE" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY="$$RUNTIME_AVAILABLE_SIM_RUNTIME_SCENE_RESULT_REQUIRE_RUNTIME_READY" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_ENABLE" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_RUNNER="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_RUNNER" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_ROAD_LENGTH_SCALE" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XOSC_OUT="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XOSC_OUT" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XODR_OUT="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_XODR_OUT" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_OUT="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_EXPORT_OUT" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_OUT="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_OUT" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XOSC="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XOSC" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XODR="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_XODR" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_CONTRACT_REQUIRE_RUNTIME_READY" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_MANIFEST_CONSISTENCY_MODE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_MANIFEST_CONSISTENCY_MODE" \
						RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_EXPORT_CONSISTENCY_MODE="$$RUNTIME_AVAILABLE_SIM_RUNTIME_INTEROP_IMPORT_EXPORT_CONSISTENCY_MODE" \
					RUNTIME_AVAILABLE_SIM_RUNTIME_ASSERT_ARTIFACTS="$$RUNTIME_AVAILABLE_SIM_RUNTIME_ASSERT_ARTIFACTS" \
					RUNTIME_AVAILABLE_PRECHECK_RUNTIME_ASSETS="$$RUNTIME_AVAILABLE_PRECHECK_RUNTIME_ASSETS" \
					RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE="$$RUNTIME_AVAILABLE_ASSET_REQUIRE_HOST_COMPATIBLE" \
					RUNTIME_AVAILABLE_ASSET_ARCHIVE_SHA256_MODE="$$RUNTIME_AVAILABLE_ASSET_ARCHIVE_SHA256_MODE"'

